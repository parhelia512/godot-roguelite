{
    "version": "0.2.0",
    "configurations": [
        //=========================================================
        // msvc debugger (Windows only)
        // Requires the Microsoft C/C++ extension
        //=========================================================
        {
            "name": "project (msvc | windows)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/extern/godot-engine/bin/godot.windows.editor.dev.x86_64.exe",
            "args": [
                "--debug",
                "--verbose",
                "--path",
                "${workspaceFolder}/project"
            ],
            "cwd": "${workspaceFolder}",
            "visualizerFile": "${workspaceFolder}/extern/godot-engine/platform/windows/godot.natvis",
            "requireExactSource": true,
            "symbolOptions": {
                "searchPaths": [
                    "${workspaceFolder}/extern/godot-engine/bin",
                    "${workspaceFolder}/project/bin"
                ],
                "searchMicrosoftSymbolServer": true
            },
            "internalConsoleOptions": "openOnSessionStart",
            "console": "internalConsole"
        },
        {
            "name": "editor (msvc | windows)",
            "type": "cppvsdbg",
            "request": "launch",
            "program": "${workspaceFolder}/extern/godot-engine/bin/godot.windows.editor.dev.x86_64.exe",
            "args": [
                "--editor",
                "--debug",
                "--verbose",
                "--path",
                "${workspaceFolder}/project"
            ],
            "cwd": "${workspaceFolder}",
            "visualizerFile": "${workspaceFolder}/extern/godot-engine/platform/windows/godot.natvis",
            "requireExactSource": true,
            "symbolOptions": {
                "searchPaths": [
                    "${workspaceFolder}/extern/godot-engine/bin",
                    "${workspaceFolder}/project/bin"
                ],
                "searchMicrosoftSymbolServer": true
            },
            "internalConsoleOptions": "openOnSessionStart",
            "console": "internalConsole"
        },
        //=========================================================
        // LLDB (favored for macOS, but also works well on Windows
        // and Linux). Requires the CodeLLDB extension, which can be
        // found as a recommended extension in this workpace
        //=========================================================
        {
            "name": "project (lldb)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/extern/godot-engine/bin/godot.macos.editor.dev.arm64",
            "linux": {
                "program": "${workspaceFolder}/extern/godot-engine/bin/godot.linuxbsd.editor.dev.x86_64"
            },
            "osx": {
                "program": "${workspaceFolder}/extern/godot-engine/bin/godot.macos.editor.dev.arm64"
            },
            "windows": {
                "program": "${workspaceFolder}/extern/godot-engine/bin/godot.windows.editor.dev.x86_64.exe",
            },
            "args": [
                "--debug",
                "--verbose",
                "--path",
                "${workspaceFolder}/project"
            ],
            "cwd": "${workspaceFolder}",
            "internalConsoleOptions": "openOnSessionStart"
        },
        {
            "name": "editor (lldb)",
            "type": "lldb",
            "request": "launch",
            "program": "${workspaceFolder}/extern/godot-engine/bin/godot.macos.editor.dev.arm64",
            "linux": {
                "program": "${workspaceFolder}/extern/godot-engine/bin/godot.linuxbsd.editor.dev.x86_64"
            },
            "osx": {
                "program": "${workspaceFolder}/extern/godot-engine/bin/godot.macos.editor.dev.arm64"
            },
            "args": [
                "--editor",
                "--debug",
                "--verbose",
                "--path",
                "${workspaceFolder}/project"
            ],
            "cwd": "${workspaceFolder}",
            "internalConsoleOptions": "openOnSessionStart"
        },
        //=========================================================
        // gdb (preferred for Linux, also works well on Windows).
        // Requiresthe Microsoft C/C++ extension.
        //=========================================================
        {
            "name": "project (gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/extern/godot-engine/bin/godot.linuxbsd.editor.dev.x86_64",
            "MIMode": "gdb",
            "linux": {
                "program": "${workspaceFolder}/extern/godot-engine/bin/godot.linuxbsd.editor.dev.x86_64",
                "miDebuggerPath": "/usr/bin/gdb"
            },
            "windows": {
                "program": "${workspaceFolder}/extern/godot-engine/bin/godot.windows.editor.dev.x86_64.exe",
                "miDebuggerPath": "gdb",
                "visualizerFile": "${workspaceFolder}/extern/godot-engine/platform/windows/godot.natvis"
            },
            "args": [
                "--debug",
                "--verbose",
                "--path",
                "${workspaceFolder}/project"
            ],
            "cwd": "${workspaceFolder}",
            "internalConsoleOptions": "openOnSessionStart",
            "launchCompleteCommand": "exec-run",
            "symbolLoadInfo": {
                "loadAll": true,
                "exceptionList": ""
            },
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        },
        {
            "name": "editor (gdb)",
            "type": "cppdbg",
            "request": "launch",
            "program": "${workspaceFolder}/extern/godot-engine/bin/godot.linuxbsd.editor.dev.x86_64",
            "MIMode": "gdb",
            "linux": {
                "program": "${workspaceFolder}/extern/godot-engine/bin/godot.linuxbsd.editor.dev.x86_64",
                "miDebuggerPath": "/usr/bin/gdb"
            },
            "windows": {
                "program": "${workspaceFolder}/extern/godot-engine/bin/godot.windows.editor.dev.x86_64.exe",
                "miDebuggerPath": "gdb",
                "visualizerFile": "${workspaceFolder}/extern/godot-engine/platform/windows/godot.natvis"
            },
            "args": [
                "--editor",
                "--debug",
                "--verbose",
                "--path",
                "${workspaceFolder}/project"
            ],
            "cwd": "${workspaceFolder}",
            "internalConsoleOptions": "openOnSessionStart",
            "launchCompleteCommand": "exec-run",
            "symbolLoadInfo": {
                "loadAll": true,
                "exceptionList": ""
            },
            "setupCommands": [
                {
                    "description": "Enable pretty-printing for gdb",
                    "text": "-enable-pretty-printing",
                    "ignoreFailures": true
                }
            ]
        }
    ]
}
